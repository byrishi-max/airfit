                      "id":  "36330eed-bd73-475e-870d-e339b2f71040",
                      "name":  "Search Exercise Video",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       1200,
                                       160
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const data = $input.first().json;\n\nif (data.isDiet) {\n  return [{ json: { ...data, exerciseMode: false, ytQuery: null } }];\n}\n\nconst wj = data.workoutJson;\nif (!wj || !wj.days || !wj.days.length) {\n  return [{ json: { ...data, exerciseMode: false, ytQuery: null } }];\n}\n\nconst items = [];\nfor (const day of wj.days) {\n  for (const ex of (day.exercises || [])) {\n    const exName  = typeof ex === \u0027string\u0027 ? ex : (ex.name || \u0027\u0027);\n    const exSets  = ex.sets ? String(ex.sets) : \u00273\u0027;\n    const exReps  = ex.reps ? String(ex.reps) : \u002710\u0027;\n    items.push({ json: {\n      exerciseMode: true,\n      exerciseName: exName,\n      sets: exSets, reps: exReps,\n      setsReps: exSets + \u0027 x \u0027 + exReps,\n      day: day.day,\n      muscle: day.muscle || \u0027\u0027,\n      ytQuery: exName + \u0027 exercise proper form tutorial gym\u0027,\n      workoutJson: data.workoutJson,\n      clientId: data.clientId,\n      clientName: data.clientName,\n      clientEmail: data.clientEmail,\n      clientPhone: data.clientPhone,\n      planType: data.planType,\n      goal: data.goal,\n      isDiet: false\n    }});\n  }\n}\nreturn items;"
                                     },
                      "id":  "fab95fbd-30ea-493c-8349-992d3c147dab",
                      "name":  "Extract Exercises",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       960,
                                       160
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const geminiResp = $input.first().json;\nconst prev = $(\u0027Build Gemini Prompt\u0027).first().json;\n\nlet rawText = geminiResp.candidates[0].content.parts[0].text;\nrawText = rawText\n  .replace(/^```json\\s*/i, \u0027\u0027)\n  .replace(/^```\\s*/i, \u0027\u0027)\n  .replace(/```\\s*$/i, \u0027\u0027)\n  .trim();\n\nif (prev.isDiet) {\n  return [{ json: {\n    isDiet: true, planHtml: rawText, workoutJson: null,\n    clientId: prev.clientId, clientName: prev.clientName,\n    clientEmail: prev.clientEmail, clientPhone: prev.clientPhone,\n    planType: prev.planType, goal: prev.goal\n  }}];\n}\n\nlet workoutJson = null;\ntry { workoutJson = JSON.parse(rawText); }\ncatch(e) {\n  const m = rawText.match(/\\{[\\s\\S]*\\}/);\n  if (m) { try { workoutJson = JSON.parse(m[0]); } catch(e2) {} }\n}\nreturn [{ json: {\n  isDiet: false, planHtml: null, workoutJson,\n  clientId: prev.clientId, clientName: prev.clientName,\n  clientEmail: prev.clientEmail, clientPhone: prev.clientPhone,\n  planType: prev.planType, goal: prev.goal\n}}];"
                                     },
                      "id":  "6ab08f2e-f96d-49aa-844c-df2cc73ac79c",
                      "name":  "Route Plan Type",
                      "type":  "n8n-nodes-base.code",
