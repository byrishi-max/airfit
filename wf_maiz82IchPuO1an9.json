                      "id":  "f35982a8-e4ba-4767-b39b-bc66217b4cc1",
                      "name":  "Generate Plan with Gemini",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       480,
                                       160
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const raw = $(\u0027Webhook Trigger\u0027).first().json;\nlet body;\nif (typeof raw.body === \u0027string\u0027) {\n  try { body = JSON.parse(raw.body); } catch(e) { body = raw.body; }\n} else {\n  body = raw.body || raw;\n}\n\nconst planType = body.planType || \u0027Workout Plan\u0027;\nconst isDiet   = planType.toLowerCase().includes(\u0027diet\u0027);\nlet prompt;\n\nif (isDiet) {\n  prompt = \u0027Expert fitness coach at Airfit Gym. Create personalised Diet Plan.\\n\\n\u0027\n    + \u0027CLIENT: \u0027 + body.name + \u0027 | \u0027 + body.gender + \u0027 | \u0027 + body.age + \u0027yrs | \u0027\n    + body.height + \u0027cm | \u0027 + body.weight + \u0027kg | Goal: \u0027 + body.goal + \u0027\\n\u0027\n    + \u0027Activity: \u0027 + body.activityLevel + \u0027 | Diet: \u0027 + body.dietPreference\n    + \u0027 | Food: \u0027 + body.foodCulture + \u0027 | Meals: \u0027 + body.mealsPerDay\n    + \u0027 | History: \u0027 + body.previousWorkout + \u0027 | Allergies: \u0027 + (body.allergies || \u0027None\u0027) + \u0027\\n\\n\u0027\n    + \u0027Create a concise DIET PLAN:\\n1. Daily calorie target and macros\\n\u0027\n    + \u00272. 7-day meal plan table (Day|Breakfast|Lunch|Dinner|Snacks)\\n\u0027\n    + \u00273. Pre/post workout meals\\n4. Hydration\\n5. Top 5 foods to avoid\\n6. 3 supplements\\n\u0027\n    + \u0027NO YouTube links.\\n\\nOUTPUT: raw HTML only, inline CSS, headings color:#ff6b00, \u0027\n    + \u0027tables border-collapse rows #1a1a1a/#222 text #e0e0e0, \u0027\n    + \u0027headers bg #ff6b00 white padding:10px, cells padding:10px border-bottom:1px solid #333. \u0027\n    + \u0027Start: \u003cp\u003eHi \u0027 + body.name + \u0027!\u003c/p\u003e\u0027;\n} else {\n  prompt = \u0027You are an expert fitness coach at Airfit Gym.\\n\\n\u0027\n    + \u0027CLIENT: \u0027 + body.name + \u0027 | \u0027 + body.gender + \u0027 | \u0027 + body.age + \u0027yrs | \u0027\n    + body.height + \u0027cm | \u0027 + body.weight + \u0027kg | Goal: \u0027 + body.goal + \u0027\\n\u0027\n    + \u0027Activity: \u0027 + body.activityLevel + \u0027 | History: \u0027 + (body.previousWorkout || \u0027Beginner\u0027) + \u0027\\n\u0027\n    + \u0027Gym Access: \u0027 + (body.gymAccess || \u0027Full Gym\u0027) + \u0027 | Focus: \u0027 + (body.focusArea || \u0027Full Body\u0027) + \u0027\\n\\n\u0027\n    + \u0027Return ONLY a valid JSON object. No markdown. No explanation. No code fences.\\n\\n\u0027\n    + \u0027Required format:\\n\u0027\n    + \u0027{\"greeting\":\"Hi \u0027 + body.name + \u0027! [motivating sentence]\",\u0027\n    + \u0027\"overview\":\"[2 sentence overview]\",\u0027\n    + \u0027\"days\":[{\"day\":\"Monday\",\"muscle\":\"Chest \u0026 Triceps\",\"exercises\":[\u0027\n    + \u0027{\"name\":\"Barbell Bench Press\",\"sets\":\"4\",\"reps\":\"8-10\"},\u0027\n    + \u0027{\"name\":\"Incline Dumbbell Press\",\"sets\":\"3\",\"reps\":\"10-12\"},\u0027\n    + \u0027{\"name\":\"Cable Fly\",\"sets\":\"3\",\"reps\":\"12-15\"},\u0027\n    + \u0027{\"name\":\"Triceps Pushdown\",\"sets\":\"3\",\"reps\":\"10-12\"},\u0027\n    + \u0027{\"name\":\"Overhead Triceps Extension\",\"sets\":\"3\",\"reps\":\"12\"}]}],\u0027\n    + \u0027\"warmup\":[\"5 min light cardio\",\"Arm circles\",\"Hip rotations\"],\u0027\n    + \u0027\"cooldown\":[\"Chest stretch 30s\",\"Triceps stretch 30s\",\"Deep breathing\"],\u0027\n    + \u0027\"recoveryTips\":[\"Sleep 7-9 hours\",\"Stay hydrated\",\"Foam roll sore muscles\"]}\\n\\n\u0027\n    + \u0027STRICT RULES:\\n\u0027\n    + \u0027- Exactly 6 workout days (Monday-Saturday). No Sunday.\\n\u0027\n    + \u0027- Exactly 5 exercises per day.\\n\u0027\n    + \u0027- Each exercise: \"name\", \"sets\", \"reps\" as strings.\\n\u0027\n    + \u0027- Output ONLY the JSON. Nothing else.\u0027;\n}\n\nreturn [{ json: {\n  geminiPayload: JSON.stringify({\n    contents: [{ parts: [{ text: prompt }] }],\n    generationConfig: { temperature: 0.7, maxOutputTokens: 4096 }\n  }),\n  clientId:    body.clientId   || \u0027\u0027,\n  clientName:  body.name       || \u0027\u0027,\n  clientEmail: body.email      || \u0027\u0027,\n  clientPhone: body.phone      || \u0027\u0027,\n  planType:    planType,\n  isDiet:      isDiet,\n  goal:        body.goal       || \u0027\u0027\n}}];"
                                     },
