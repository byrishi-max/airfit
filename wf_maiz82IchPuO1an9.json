                      "id":  "fc09fa40-57b2-4a88-a344-df55a55e9b04",
                      "name":  "Save Plan to Store",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       2160,
                                       160
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const data      = $input.first().json;\nconst clientCtx = $(\u0027Build Gemini Prompt\u0027).first().json;\n\nconst clientId    = data.clientId    || clientCtx.clientId    || \u0027\u0027;\nconst clientName  = data.clientName  || clientCtx.clientName  || \u0027\u0027;\nconst clientEmail = data.clientEmail || clientCtx.clientEmail || \u0027\u0027;\nconst clientPhone = data.clientPhone || clientCtx.clientPhone || \u0027\u0027;\nconst planType    = data.planType    || clientCtx.planType    || \u0027\u0027;\nconst isDiet      = data.isDiet;\n\nreturn [{ json: {\n  clientId,\n  clientName,\n  clientEmail,\n  clientPhone,\n  planType,\n  isDiet,\n  workoutJson:  isDiet ? null : data.workoutJson,\n  dietHtml:     isDiet ? data.planHtml : null,\n  generatedAt:  new Date().toISOString()\n}}];"
                                     },
                      "id":  "e49cef3d-9975-41ce-ab05-545ce2b8517d",
                      "name":  "Build Plan Response",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1920,
                                       160
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const allItems  = $input.all();\nconst base      = allItems[0].json;\nconst clientCtx = $(\u0027Build Gemini Prompt\u0027).first().json;\n\nif (!base.exerciseMode) {\n  return [{ json: {\n    ...base,\n    clientId:    clientCtx.clientId,\n    clientName:  clientCtx.clientName,\n    clientEmail: clientCtx.clientEmail,\n    clientPhone: clientCtx.clientPhone,\n    planType:    clientCtx.planType\n  }}];\n}\n\nconst wj = base.workoutJson;\nconst dayMap = new Map();\nfor (const item of allItems) {\n  const d = item.json;\n  if (!dayMap.has(d.day)) dayMap.set(d.day, { day: d.day, muscle: d.muscle, exercises: [] });\n  dayMap.get(d.day).exercises.push({\n    name: d.exerciseName, sets: d.sets, reps: d.reps,\n    setsReps: d.setsReps,\n    videoId: d.videoId, videoUrl: d.videoUrl,\n    videoTitle: d.videoTitle, channelName: d.channelName, thumb: d.thumb\n  });\n}\n\nconst enrichedDays = Array.from(dayMap.values());\nconst enrichedWorkoutJson = {\n  greeting:     wj ? wj.greeting     : \u0027\u0027,\n  overview:     wj ? wj.overview     : \u0027\u0027,\n  warmup:       wj ? wj.warmup       : [],\n  cooldown:     wj ? wj.cooldown     : [],\n  recoveryTips: wj ? wj.recoveryTips : [],\n  days: enrichedDays\n};\n\nreturn [{ json: {\n  isDiet:       false,\n  workoutJson:  enrichedWorkoutJson,\n  planHtml:     null,\n  clientId:     clientCtx.clientId,\n  clientName:   clientCtx.clientName,\n  clientEmail:  clientCtx.clientEmail,\n  clientPhone:  clientCtx.clientPhone,\n  planType:     clientCtx.planType\n}}];"
                                     },
                      "id":  "250de3e1-803b-48b2-883f-0b7e1fba8cac",
                      "name":  "Rebuild Workout Plan",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1680,
                                       160
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const ytItems   = $input.all();\nconst exItems   = $(\u0027Extract Exercises\u0027).all();\nconst clientCtx = $(\u0027Build Gemini Prompt\u0027).first().json;\nconst output    = [];\n\nfor (let i = 0; i \u003c ytItems.length; i++) {\n  const ytResp = ytItems[i].json;\n  const exCtx  = exItems[i] ? exItems[i].json : {};\n\n  let videoId = null, videoUrl = null, videoTitle = null, channelName = null, thumb = null;\n  try {\n    const yt = ytResp.items \u0026\u0026 ytResp.items[0];\n    if (yt \u0026\u0026 yt.id \u0026\u0026 yt.id.videoId) {\n      videoId     = yt.id.videoId;\n      videoUrl    = \u0027https://www.youtube.com/watch?v=\u0027 + videoId;\n      videoTitle  = yt.snippet.title;\n      channelName = yt.snippet.channelTitle;\n      const t     = yt.snippet.thumbnails;\n      thumb       = (t.medium || t.default || {}).url || null;\n    }\n  } catch(e) {}\n\n  output.push({ json: {\n    exerciseMode: true,\n    exerciseName: exCtx.exerciseName || \u0027\u0027,\n    sets: exCtx.sets || \u00273\u0027, reps: exCtx.reps || \u002710\u0027,\n    setsReps: exCtx.setsReps || \u00273 x 10\u0027,\n    day: exCtx.day || \u0027\u0027, muscle: exCtx.muscle || \u0027\u0027,\n    videoId, videoUrl, videoTitle, channelName, thumb,\n    workoutJson: exCtx.workoutJson || null,\n    clientId:    clientCtx.clientId,\n    clientName:  clientCtx.clientName,\n    clientEmail: clientCtx.clientEmail,\n    clientPhone: clientCtx.clientPhone,\n    planType:    clientCtx.planType,\n    goal:        clientCtx.goal,\n    isDiet: false\n  }});\n}\nreturn output;"
                                     },
                      "id":  "b7a087a7-feff-498d-ac8a-ef2531a1da22",
                      "name":  "Attach Exercise Video",
