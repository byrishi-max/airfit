                  {
                      "parameters":  {
                                         "jsCode":  "const raw = $input.first().json;\n\n// Unwrap webhook v2 envelope\nconst body = (raw.body \u0026\u0026 typeof raw.body === \u0027object\u0027 \u0026\u0026 Object.keys(raw.body).length \u003e 0)\n             ? raw.body\n             : raw;\n\nconst name   = body.name   || \u0027Athlete\u0027;\nconst email  = body.email  || \u0027\u0027;\nconst phone  = body.phone  || \u0027\u0027;\nconst appUrl = body.appUrl || \u0027https://workoutplanairfit.vercel.app/client/login\u0027;\n\nif (!email) {\n  throw new Error(\u0027Missing email address. Received keys: \u0027 + Object.keys(body).join(\u0027, \u0027));\n}\n\nconst html = `\u003c!DOCTYPE html\u003e\n\u003chtml\u003e\n\u003chead\u003e\u003cmeta charset=\"UTF-8\"\u003e\u003cmeta name=\"viewport\" content=\"width=device-width,initial-scale=1\"\u003e\u003c/head\u003e\n\u003cbody style=\"margin:0;padding:0;background:#0d0d0d;font-family:Arial,Helvetica,sans-serif;\"\u003e\n\u003ctable width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#0d0d0d;padding:32px 0;\"\u003e\n\u003ctr\u003e\u003ctd align=\"center\"\u003e\n\u003ctable width=\"520\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#111;border-radius:14px;overflow:hidden;border:1px solid #1a1a1a;\"\u003e\n  \u003ctr\u003e\u003ctd style=\"background:linear-gradient(135deg,#FF5C1A 0%,#cc2200 100%);padding:36px 32px;text-align:center;\"\u003e\n    \u003ch1 style=\"color:#fff;font-size:26px;margin:0;letter-spacing:8px;font-weight:900;text-transform:uppercase;\"\u003eAIRFIT GYM\u003c/h1\u003e\n    \u003cdiv style=\"width:40px;height:3px;background:rgba(255,255,255,0.3);margin:12px auto;border-radius:2px;\"\u003e\u003c/div\u003e\n    \u003cp style=\"color:rgba(255,255,255,0.75);font-size:11px;margin:0;letter-spacing:3px;text-transform:uppercase;\"\u003eTraining Portal Invite\u003c/p\u003e\n  \u003c/td\u003e\u003c/tr\u003e\n  \u003ctr\u003e\u003ctd style=\"padding:32px;\"\u003e\n    \u003cp style=\"color:#f0f0f0;font-size:16px;font-weight:700;margin:0 0 12px;\"\u003eHey ${name}! 👋\u003c/p\u003e\n    \u003cp style=\"color:#aaa;font-size:14px;line-height:1.7;margin:0 0 20px;\"\u003e\n      You\u0027ve been added to the \u003cstrong style=\"color:#FF5C1A;\"\u003eAirfit Gym Training Portal\u003c/strong\u003e.\n      Your personalized AI workout plan is waiting — just login and fill out a quick questionnaire,\n      and within 60 minutes you\u0027ll have a fully custom 6-day plan with YouTube tutorials for every exercise.\n    \u003c/p\u003e\n    \u003cdiv style=\"text-align:center;margin:28px 0;\"\u003e\n      \u003ca href=\"${appUrl}\" style=\"display:inline-block;background:linear-gradient(90deg,#FF5C1A,#cc3300);color:#fff;padding:15px 36px;border-radius:8px;text-decoration:none;font-weight:900;font-size:14px;letter-spacing:2px;text-transform:uppercase;\"\u003e\n        Enter Training Portal →\n      \u003c/a\u003e\n    \u003c/div\u003e\n    \u003cdiv style=\"background:#0d0d0d;border-radius:10px;padding:18px;border:1px solid #1a1a1a;margin-top:20px;\"\u003e\n      \u003cp style=\"color:#555;font-size:11px;text-transform:uppercase;letter-spacing:2px;margin:0 0 10px;\"\u003eHOW TO LOGIN\u003c/p\u003e\n      \u003cp style=\"color:#888;font-size:13px;margin:0 0 8px;\"\u003e1. Click the button above\u003c/p\u003e\n      \u003cp style=\"color:#888;font-size:13px;margin:0 0 8px;\"\u003e2. Enter your phone number: \u003cstrong style=\"color:#FF5C1A;font-family:monospace;letter-spacing:2px;\"\u003e${phone}\u003c/strong\u003e\u003c/p\u003e\n      \u003cp style=\"color:#888;font-size:13px;margin:0;\"\u003e3. Fill your fitness questionnaire \u0026 get your AI plan!\u003c/p\u003e\n    \u003c/div\u003e\n  \u003c/td\u003e\u003c/tr\u003e\n  \u003ctr\u003e\u003ctd style=\"padding:0 32px;\"\u003e\u003cdiv style=\"height:1px;background:linear-gradient(90deg,transparent,#FF5C1A,transparent);\"\u003e\u003c/div\u003e\u003c/td\u003e\u003c/tr\u003e\n  \u003ctr\u003e\u003ctd style=\"background:#0a0a0a;padding:22px 32px;text-align:center;\"\u003e\n    \u003cp style=\"color:#FF5C1A;font-size:13px;font-weight:900;margin:0 0 6px;letter-spacing:1px;\"\u003e💪 Train Smart. Train Hard. Train With AI.\u003c/p\u003e\n    \u003cp style=\"color:#2a2a2a;font-size:10px;margin:0;letter-spacing:1px;\"\u003eAIRFIT GYM © 2025\u003c/p\u003e\n  \u003c/td\u003e\u003c/tr\u003e\n\u003c/table\u003e\n\u003c/td\u003e\u003c/tr\u003e\u003c/table\u003e\n\u003c/body\u003e\u003c/html\u003e`;\n\nreturn [{ json: {\n  toEmail:  email,\n  subject:  \"🏋️ You\u0027re Invited to Airfit Gym Training Portal!\",\n  htmlBody: html,\n  name,\n  phone\n}}];"
                                     },
