                      "id":  "66f0d344-e469-46b5-9dc5-4e7cebb947a2",
                      "name":  "Register Client",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  2,
                      "position":  [
                                       0,
                                       832
                                   ],
                      "webhookId":  "airfit-register-client-wh"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// POST /airfit-register-client\n// Admin adds a new client — stores their record in static data\n// Body: { clientId, name, email, phone }\nconst store = $getWorkflowStaticData(\u0027global\u0027);\nconst raw   = $input.first().json;\n\nconst body = (raw.body \u0026\u0026 typeof raw.body === \u0027object\u0027 \u0026\u0026 Object.keys(raw.body).length \u003e 0)\n             ? raw.body : raw;\n\nconst clientId = body.clientId || (\u0027client_\u0027 + Date.now());\nconst name     = body.name     || \u0027\u0027;\nconst email    = body.email    || \u0027\u0027;\nconst phone    = body.phone    || \u0027\u0027;\n\nif (!name || !phone) {\n  return [{ json: { success: false, error: \u0027name and phone are required\u0027 } }];\n}\n\n// Don\u0027t overwrite if already has a plan\nif (store[clientId] \u0026\u0026 store[clientId].status === \u0027ready\u0027) {\n  return [{ json: { success: true, clientId, message: \u0027Client already has a plan — not overwritten\u0027 } }];\n}\n\nstore[clientId] = {\n  clientId,\n  clientName:  name,\n  clientEmail: email,\n  clientPhone: phone,\n  planType:    \u0027\u0027,\n  isDiet:      false,\n  workoutJson: null,\n  dietHtml:    null,\n  generatedAt: \u0027\u0027,\n  status:      \u0027none\u0027,   // \u0027none\u0027 | \u0027pending\u0027 | \u0027ready\u0027\n  registeredAt: new Date().toISOString()\n};\n\nreturn [{ json: { success: true, clientId, name, email, phone } }];"
                                     },
