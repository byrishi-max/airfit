                      "id":  "e4c0362b-8ee6-4869-84c1-efec639a5c2f",
                      "name":  "Get Clients",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  2,
                      "position":  [
                                       0,
                                       416
                                   ],
                      "webhookId":  "airfit-get-clients-wh"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// GET /airfit-get-clients\n// Returns all clients stored in static data as a flat array\n// Also accepts ?phone=xxx to filter by phone (for VERIFY_CLIENT)\nconst store = $getWorkflowStaticData(\u0027global\u0027);\nconst raw   = $input.first().json;\n\n// Build array of all client entries\n// static data keys: clientId entries (client_xxx) + any other metadata\nconst allClients = Object.entries(store)\n  .filter(([key, val]) =\u003e key.startsWith(\u0027client_\u0027) \u0026\u0026 typeof val === \u0027object\u0027 \u0026\u0026 val !== null)\n  .map(([_, val]) =\u003e ({\n    clientId:    val.clientId    || \u0027\u0027,\n    name:        val.clientName  || \u0027\u0027,\n    email:       val.clientEmail || \u0027\u0027,\n    phone:       val.clientPhone || \u0027\u0027,\n    planStatus:  val.status      || \u0027pending\u0027,\n    planType:    val.planType    || \u0027\u0027,\n    generatedAt: val.generatedAt || \u0027\u0027,\n    isDiet:      val.isDiet      || false\n  }));\n\nreturn [{ json: { clients: allClients, total: allClients.length } }];"
                                     },
