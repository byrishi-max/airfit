                      "id":  "d0da7ebf-51e0-4a30-bb00-39849ce5022b",
                      "name":  "Get Plan",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  2,
                      "position":  [
                                       0,
                                       208
                                   ],
                      "webhookId":  "airfit-get-plan-wh"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Web app polls this to check if plan is ready\nconst store = $getWorkflowStaticData(\u0027global\u0027);\nconst raw   = $input.first().json;\n\n// GET requests: clientId comes in query params — try all access patterns\nconst clientId = raw.query?.clientId\n              || raw.params?.clientId\n              || raw.body?.clientId\n              || raw.clientId\n              || \u0027\u0027;\n\nif (!clientId) {\n  return [{ json: { status: \u0027error\u0027, error: \u0027Missing clientId\u0027 } }];\n}\n\nconst plan = store[clientId];\nif (!plan) {\n  return [{ json: { status: \u0027pending\u0027, clientId } }];\n}\n\nreturn [{ json: { status: \u0027ready\u0027, ...plan } }];"
                                     },
