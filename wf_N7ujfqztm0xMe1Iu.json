                      "id":  "2dbb56ab-92bc-427b-9698-bc0ea4cb2f70",
                      "name":  "Receive Plan",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  2,
                      "position":  [
                                       0,
                                       0
                                   ],
                      "webhookId":  "airfit-plan-ready-wh"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Receives completed plan from Plan Generator, stores in static data\nconst store = $getWorkflowStaticData(\u0027global\u0027);\nconst raw   = $input.first().json;\n\n// Unwrap webhook v2 envelope — body may be nested or flat\nconst body  = (raw.body \u0026\u0026 typeof raw.body === \u0027object\u0027 \u0026\u0026 Object.keys(raw.body).length \u003e 0)\n              ? raw.body\n              : raw;\n\nif (!body.clientId) {\n  return [{ json: { success: false, error: \u0027Missing clientId\u0027 } }];\n}\n\nstore[body.clientId] = {\n  clientId:    body.clientId,\n  clientName:  body.clientName  || \u0027\u0027,\n  clientEmail: body.clientEmail || \u0027\u0027,\n  clientPhone: body.clientPhone || \u0027\u0027,\n  planType:    body.planType    || \u0027\u0027,\n  isDiet:      !!body.isDiet,\n  workoutJson: body.workoutJson || null,\n  dietHtml:    body.dietHtml    || null,\n  generatedAt: body.generatedAt || new Date().toISOString(),\n  status:      \u0027ready\u0027\n};\n\nreturn [{ json: { success: true, clientId: body.clientId } }];"
                                     },
