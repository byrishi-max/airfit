                  {
                      "parameters":  {
                                         "path":  "airfit-verify-client",
                                         "responseMode":  "responseNode",
                                         "options":  {

                                                     }
                                     },
                      "id":  "9569e063-9fef-43b8-8ad4-bf795ff3ad12",
                      "name":  "Verify Client",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  2,
                      "position":  [
                                       0,
                                       624
                                   ],
                      "webhookId":  "airfit-verify-client-wh"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// GET /airfit-verify-client?phone=9876543210\n// Also supports ?clientId=client_xxx for direct lookup\n// Returns single client object or { error: \u0027not_found\u0027 }\nconst store = $getWorkflowStaticData(\u0027global\u0027);\nconst raw   = $input.first().json;\n\nconst phone    = raw.query?.phone    || raw.phone    || \u0027\u0027;\nconst clientId = raw.query?.clientId || raw.clientId || \u0027\u0027;\n\n// Search by clientId first (faster)\nif (clientId \u0026\u0026 store[clientId]) {\n  const val = store[clientId];\n  return [{ json: {\n    found:       true,\n    clientId:    val.clientId    || \u0027\u0027,\n    name:        val.clientName  || \u0027\u0027,\n    email:       val.clientEmail || \u0027\u0027,\n    phone:       val.clientPhone || \u0027\u0027,\n    planStatus:  val.status      || \u0027pending\u0027,\n    planType:    val.planType    || \u0027\u0027,\n    generatedAt: val.generatedAt || \u0027\u0027,\n    isDiet:      val.isDiet      || false,\n    workoutJson: val.workoutJson || null,\n    dietHtml:    val.dietHtml    || null\n  }}];\n}\n\n// Search by phone number (normalize: strip spaces, leading zeros, country code)\nif (phone) {\n  const normalize = (p) =\u003e (p || \u0027\u0027).replace(/\\D/g, \u0027\u0027).slice(-10);\n  const searchPhone = normalize(phone);\n\n  const match = Object.values(store).find(val =\u003e\n    typeof val === \u0027object\u0027 \u0026\u0026 val !== null \u0026\u0026\n    normalize(val.clientPhone) === searchPhone\n  );\n\n  if (match) {\n    return [{ json: {\n      found:       true,\n      clientId:    match.clientId    || \u0027\u0027,\n      name:        match.clientName  || \u0027\u0027,\n      email:       match.clientEmail || \u0027\u0027,\n      phone:       match.clientPhone || \u0027\u0027,\n      planStatus:  match.status      || \u0027pending\u0027,\n      planType:    match.planType    || \u0027\u0027,\n      generatedAt: match.generatedAt || \u0027\u0027,\n      isDiet:      match.isDiet      || false,\n      workoutJson: match.workoutJson || null,\n      dietHtml:    match.dietHtml    || null\n    }}];\n  }\n}\n\n// Not found\nreturn [{ json: { found: false, error: \u0027not_found\u0027, phone, clientId } }];"
                                     },
